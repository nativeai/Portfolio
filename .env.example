# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# Node Environment
NODE_ENV=development

# ==============================================
# SECURITY GUIDELINES
# ==============================================
# 1. NEVER commit .env.local, .env.production, or any file containing secrets
# 2. Use strong, unique values for all secrets (minimum 32 characters)
# 3. Rotate secrets regularly (every 90 days recommended)
# 4. Use different secrets for development, staging, and production
# 5. Restrict access to production environment variables
# 6. Use environment-specific secrets management (AWS Secrets Manager, Vault, etc.)
# ==============================================

# Add your environment variables below
# Example:
# API_KEY=your_api_key_here
# DATABASE_URL=your_database_url_here
# NEXTAUTH_SECRET=your_nextauth_secret_here
# NEXTAUTH_URL=http://localhost:3000

# ==============================================
# TALKIVO CHAT WIDGET
# ==============================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here   # optional — falls back to browser TTS
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token_here  # optional — for meeting booking
HUBSPOT_MEETING_SLUG=your_hubspot_meeting_slug_here  # optional
